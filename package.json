{
  "name": "@ola-turmo/paperclip-personal-health",
  "version": "0.2.0",
  "description": "Living personal health plugin for Paperclip with workouts, nutrition, medications, labs, wearables, and genetic-health insights",
  "author": "turmo.dev",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "npm run plugin:build",
    "plugin:typecheck": "tsc -p tsconfig.plugin.json --noEmit",
    "plugin:build": "node esbuild.config.mjs",
    "plugin:dev": "node ./esbuild.config.mjs --watch",
    "plugin:test": "vitest run",
    "test": "npm run plugin:test && node tests/smoke.mjs"
  },
  "devDependencies": {
    "@paperclipai/plugin-sdk": "^2026.416.0",
    "@paperclipai/shared": "^2026.416.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
